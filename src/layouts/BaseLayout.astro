---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  jsonLd?: object | object[];
}

const { title, description, locale, path, image, type, jsonLd } = Astro.props;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'DeAging Europe',
  url: (Astro.site ?? new URL('https://deagingeurope.example')).toString(),
  description: 'Evidence-based anti-aging information and products for Europe.',
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
    />
    <SEO
      title={title}
      description={description}
      locale={locale}
      path={path}
      image={image}
      type={type}
      jsonLd={[orgJsonLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])]}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header locale={locale} path={path ?? ''} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
