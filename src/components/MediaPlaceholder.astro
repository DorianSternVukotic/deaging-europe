---
/**
 * Generic media placeholder for image/video slots while real assets aren't ready.
 *
 * Renders a styled box with an icon, optional label and caption, and an
 * aspect-ratio container so layout doesn't jump when the real asset drops in.
 */
interface Props {
  /** "image" or "video" — controls the icon */
  kind?: 'image' | 'video';
  /** CSS aspect ratio (e.g. "16/9", "4/5", "1/1") */
  ratio?: string;
  /** Short label inside the placeholder */
  label?: string;
  /** Caption below the box */
  caption?: string;
  /** Optional extra classes */
  class?: string;
  /** Show a subtle background tint variant */
  tone?: 'bone' | 'rose' | 'sage' | 'gold';
}

const {
  kind = 'image',
  ratio = '16/9',
  label,
  caption,
  class: klass = '',
  tone = 'bone',
} = Astro.props;

const tones: Record<string, string> = {
  bone: 'bg-bone border-ink/10 text-ink/40',
  rose: 'bg-rose/10 border-rose/20 text-rose/70',
  sage: 'bg-sage/10 border-sage/20 text-sage/80',
  gold: 'bg-gold/10 border-gold/20 text-gold/80',
};
---

<figure class={`media-ph ${klass}`}>
  <div
    class={`relative w-full overflow-hidden rounded-xl border border-dashed ${tones[tone]} flex items-center justify-center`}
    style={`aspect-ratio: ${ratio};`}
    role="img"
    aria-label={label ?? (kind === 'video' ? 'Video placeholder' : 'Image placeholder')}
  >
    <div class="absolute inset-0 opacity-40 pointer-events-none" style="background-image: repeating-linear-gradient(45deg, currentColor 0 1px, transparent 1px 14px);"></div>
    <div class="relative flex flex-col items-center gap-2 px-4 text-center">
      {kind === 'video' ? (
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/>
        </svg>
      ) : (
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      )}
      {label && <p class="text-[11px] uppercase tracking-[0.25em] font-medium">{label}</p>}
    </div>
  </div>
  {caption && (
    <figcaption class="mt-2 text-xs text-ink/55 italic">{caption}</figcaption>
  )}
</figure>
