---
import { type Locale } from '../i18n/ui';
import { t } from '../i18n/utils';
interface Props { locale: Locale }
const { locale } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="border-t border-ink/10 mt-24 bg-ink text-bone">
  <div class="max-w-6xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-8 text-sm">
    <div>
      <div class="font-display text-2xl">de<span class="text-rose">∞</span>aging europe</div>
      <p class="mt-3 text-bone/70">{t(locale, 'footer.tagline')}</p>
    </div>
    <div>
      <h3 class="font-display text-lg mb-3">Disclaimer</h3>
      <p class="text-bone/70">{t(locale, 'footer.disclaimer')}</p>
    </div>
    <div>
      <h3 class="font-display text-lg mb-3">© {year}</h3>
      <p class="text-bone/70">DeAging Europe. All rights reserved.</p>
    </div>
  </div>
</footer>
