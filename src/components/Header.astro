---
import { LOCALES, LOCALE_NAMES, type Locale } from '../i18n/ui';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
---
<header class="border-b border-ink/10 bg-bone/90 backdrop-blur sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-6">
    <a href={localePath(locale, '')} class="font-display text-2xl tracking-tight">
      <span class="text-ink">de<span class="text-rose">∞</span>aging</span>
      <span class="text-sage text-sm align-super ml-1">europe</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a class="hover:text-rose transition" href={localePath(locale, '#problems')}>{t(locale, 'nav.problems')}</a>
      <a class="hover:text-rose transition" href={localePath(locale, '#products')}>{t(locale, 'nav.products')}</a>
      <a class="hover:text-rose transition" href={localePath(locale, '#science')}>{t(locale, 'nav.science')}</a>
    </nav>

    <form class="flex items-center" data-no-js-fallback>
      <label for="lang" class="sr-only">Language</label>
      <select
        id="lang"
        class="bg-transparent border border-ink/20 rounded-full px-3 py-1 text-sm focus:outline-none focus:border-rose"
        onchange="if(this.value) window.location.href=this.value"
      >
        {LOCALES.map((l) => (
          <option value={localePath(l, path)} selected={l === locale}>{LOCALE_NAMES[l]}</option>
        ))}
      </select>
      <noscript>
        <ul class="flex gap-2 text-xs ml-2">
          {LOCALES.map((l) => (
            <li>
              <a class={l === locale ? 'underline' : ''} href={localePath(l, path)}>{l.toUpperCase()}</a>
            </li>
          ))}
        </ul>
      </noscript>
    </form>
  </div>
</header>
