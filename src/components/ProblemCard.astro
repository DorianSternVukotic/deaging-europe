---
import { type Locale } from '../i18n/ui';
import { localePath, t } from '../i18n/utils';

interface Props {
  locale: Locale;
  slug: string;
  title: string;
  bodyArea: string;
  image: string;
  summary: string;
  topSolutions: { name: string }[];
}
const { locale, slug, title, bodyArea, image, summary, topSolutions } = Astro.props;
---
<a
  href={localePath(locale, `problems/${slug}`)}
  class="group block bg-white rounded-2xl overflow-hidden border border-ink/5 shadow-sm hover:shadow-xl transition-shadow"
>
  <div class="aspect-[4/3] overflow-hidden bg-bone">
    <img
      src={image}
      alt={`${title} — ${bodyArea}`}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>
  <div class="p-6">
    <p class="text-xs uppercase tracking-widest text-sage">{t(locale, 'problem.bodyArea')}: {bodyArea}</p>
    <h3 class="font-display text-2xl mt-1 group-hover:text-rose transition">{title}</h3>
    <p class="mt-2 text-sm text-ink/70 leading-relaxed">{summary}</p>
    {topSolutions.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2">
        {topSolutions.map((s) => (
          <li class="text-xs px-3 py-1 rounded-full bg-bone border border-ink/10">{s.name}</li>
        ))}
      </ul>
    )}
  </div>
</a>
