---
// Default-locale (en) homepage lives at "/"
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProblemCard from '../components/ProblemCard.astro';
import { localePath, t } from '../i18n/utils';
import { type Locale } from '../i18n/ui';

const locale: Locale = 'en';

const allProblems = await getCollection('problems', ({ data }) => data.locale === locale);
const allProducts = await getCollection('products', ({ data }) => data.locale === locale);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allProblems.slice(0, 5).map((p) => ({
    '@type': 'Question',
    name: `What helps with ${p.data.title.toLowerCase()}?`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: `${p.data.summary} Top solutions: ${p.data.solutions.slice(0, 3).map((s) => s.name).join(', ')}.`,
    },
  })),
};
---
<BaseLayout
  title="DeAging Europe — Evidence-based anti-aging information & products"
  description="The European hub for anti-aging protocols, ingredients and devices that actually work — backed by science, reviewed by clinicians."
  locale={locale}
  jsonLd={faqJsonLd}
>
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <p class="text-xs uppercase tracking-[0.4em] text-sage">{t(locale, 'home.hero.eyebrow')}</p>
      <h1 class="font-display text-5xl md:text-7xl mt-6 max-w-4xl leading-[1.05]">
        {t(locale, 'home.hero.title')}
      </h1>
      <p class="mt-8 text-xl text-ink/75 max-w-2xl leading-relaxed">{t(locale, 'home.hero.sub')}</p>
      <div class="mt-10 flex gap-4 flex-wrap">
        <a href="#problems" class="bg-ink text-bone px-8 py-4 rounded-full font-semibold hover:bg-rose transition">
          {t(locale, 'home.cta.explore')}
        </a>
        <a href="/collagen-5" class="border border-ink/20 px-8 py-4 rounded-full font-semibold hover:border-ink hover:bg-ink/5 transition">
          Read the collagen guide
        </a>
        <a href="/jowls" class="border border-ink/20 px-8 py-4 rounded-full font-semibold hover:border-ink hover:bg-ink/5 transition">
          Read the jowls guide
        </a>
      </div>
    </div>
    <div class="absolute -right-32 -top-32 w-96 h-96 bg-rose/10 rounded-full blur-3xl pointer-events-none"></div>
  </section>

  <section id="problems" class="py-20 bg-white border-t border-ink/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12">
        <h2 class="font-display text-4xl md:text-5xl">{t(locale, 'home.problems.title')}</h2>
        <p class="mt-4 text-ink/70 text-lg">{t(locale, 'home.problems.sub')}</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {allProblems.map((p) => (
          <ProblemCard
            locale={locale}
            slug={p.data.slug}
            title={p.data.title}
            bodyArea={p.data.bodyArea}
            image={p.data.image}
            summary={p.data.summary}
            topSolutions={p.data.solutions.slice(0, 3)}
          />
        ))}
      </div>
    </div>
  </section>

  <section id="products" class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-4xl md:text-5xl mb-10">Featured products</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {allProducts.map((p) => (
          <a href={localePath(locale, `products/${p.data.slug}`)} class="group block bg-white rounded-2xl overflow-hidden border border-ink/5 hover:shadow-xl transition-shadow">
            <div class="aspect-square bg-bone overflow-hidden">
              <img src={p.data.image} alt={p.data.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <p class="text-xs uppercase tracking-widest text-sage">{p.data.brand}</p>
              <h3 class="font-display text-2xl mt-1">{p.data.title}</h3>
              <p class="mt-2 text-sm text-ink/70">{p.data.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
