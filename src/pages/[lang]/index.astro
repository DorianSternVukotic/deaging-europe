---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProblemCard from '../../components/ProblemCard.astro';
import { localePath, t, getLocaleFromParams } from '../../i18n/utils';
import { LOCALES, DEFAULT_LOCALE } from '../../i18n/ui';

export async function getStaticPaths() {
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({ params: { lang } }));
}

const locale = getLocaleFromParams(Astro.params.lang);

const allProblems = await getCollection('problems', ({ data }) => data.locale === locale);
const allProducts = await getCollection('products', ({ data }) => data.locale === locale);

const faqJsonLd = allProblems.length === 0 ? null : {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allProblems.slice(0, 5).map((p) => ({
    '@type': 'Question',
    name: p.data.title,
    acceptedAnswer: { '@type': 'Answer', text: p.data.summary },
  })),
};
---
<BaseLayout
  title={`DeAging Europe — ${t(locale, 'home.hero.title')}`}
  description={t(locale, 'home.hero.sub')}
  locale={locale}
  jsonLd={faqJsonLd ?? undefined}
>
  <section class="max-w-6xl mx-auto px-6 py-24 md:py-32">
    <p class="text-xs uppercase tracking-[0.4em] text-sage">{t(locale, 'home.hero.eyebrow')}</p>
    <h1 class="font-display text-5xl md:text-7xl mt-6 max-w-4xl leading-[1.05]">{t(locale, 'home.hero.title')}</h1>
    <p class="mt-8 text-xl text-ink/75 max-w-2xl leading-relaxed">{t(locale, 'home.hero.sub')}</p>
  </section>

  <section id="problems" class="py-20 bg-white border-t border-ink/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12">
        <h2 class="font-display text-4xl md:text-5xl">{t(locale, 'home.problems.title')}</h2>
        <p class="mt-4 text-ink/70 text-lg">{t(locale, 'home.problems.sub')}</p>
      </div>
      {allProblems.length === 0 ? (
        <p class="text-ink/60">Translations coming soon. <a class="underline" href="/">Read in English</a>.</p>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {allProblems.map((p) => (
            <ProblemCard
              locale={locale}
              slug={p.data.slug}
              title={p.data.title}
              bodyArea={p.data.bodyArea}
              image={p.data.image}
              summary={p.data.summary}
              topSolutions={p.data.solutions.slice(0, 3)}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  {allProducts.length > 0 && (
    <section id="products" class="py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="font-display text-4xl md:text-5xl mb-10">{t(locale, 'nav.products')}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {allProducts.map((p) => (
            <a href={localePath(locale, `products/${p.data.slug}`)} class="group block bg-white rounded-2xl overflow-hidden border border-ink/5 hover:shadow-xl transition-shadow">
              <div class="aspect-square bg-bone overflow-hidden">
                <img src={p.data.image} alt={p.data.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-6">
                <p class="text-xs uppercase tracking-widest text-sage">{p.data.brand}</p>
                <h3 class="font-display text-2xl mt-1">{p.data.title}</h3>
                <p class="mt-2 text-sm text-ink/70">{p.data.tagline}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
