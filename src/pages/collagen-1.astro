---
/**
 * Variation 1 — Hub / Dashboard
 *
 * Landing tile grid. Each major topic group is a card. Selecting one
 * scrolls to its detail panel which contains the full cards. Compact,
 * browse-y feel for people who want to skim categories before reading.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaPlaceholder from '../components/MediaPlaceholder.astro';
import { DEFAULT_LOCALE } from '../i18n/ui';
import {
  heroFacts,
  keyTakeaways,
  groups,
  evidenceLabels,
  focusLabels,
  type Evidence,
} from '../data/collagen';

const locale = DEFAULT_LOCALE;
const title = 'Collagen — Hub view | DeAging Europe';
const description = 'Pick a topic. Each tile opens a detail panel with the full evidence.';

const tileMeta: Record<string, { icon: string; tone: string }> = {
  basics: { icon: '◐', tone: 'bg-sage/10 text-sage border-sage/20' },
  benefits: { icon: '✚', tone: 'bg-rose/10 text-rose border-rose/20' },
  loss: { icon: '↘', tone: 'bg-gold/10 text-gold border-gold/20' },
  'boost-diet': { icon: '◇', tone: 'bg-sage/10 text-sage border-sage/20' },
  'boost-topical': { icon: '✦', tone: 'bg-rose/10 text-rose border-rose/20' },
  'boost-clinical': { icon: '✕', tone: 'bg-gold/10 text-gold border-gold/20' },
  safety: { icon: '⚠', tone: 'bg-ink/10 text-ink/70 border-ink/15' },
  faq: { icon: '?', tone: 'bg-sage/10 text-sage border-sage/20' },
};

const evidencePillClass = (e?: Evidence) =>
  e === 'strong'
    ? 'bg-sage/15 text-sage'
    : e === 'moderate'
    ? 'bg-gold/15 text-gold'
    : e === 'emerging'
    ? 'bg-rose/15 text-rose'
    : 'bg-ink/10 text-ink/60';
---

<BaseLayout title={title} description={description} locale={locale} path="collagen-1" type="article">
  <article class="bg-bone">
    <!-- HERO -->
    <header class="border-b border-ink/10">
      <div class="max-w-6xl mx-auto px-6 py-14 grid lg:grid-cols-[1fr_auto] gap-10 items-end">
        <div>
          <p class="text-xs uppercase tracking-[0.4em] text-sage">Hub view · Variation 1</p>
          <h1 class="font-display text-5xl md:text-6xl mt-4 leading-[1.05] max-w-3xl">
            Collagen, the dashboard
          </h1>
          <p class="mt-4 max-w-2xl text-lg text-ink/75">
            Eight topic tiles. Pick one — the rest stays out of the way. Good when you know what
            you're looking for.
          </p>
        </div>
        <MediaPlaceholder kind="image" ratio="4/5" label="Hero photo" tone="rose" class="w-full lg:w-72" />
      </div>
    </header>

    <!-- KEY FACTS STRIP -->
    <section class="border-b border-ink/10 bg-white">
      <div class="max-w-6xl mx-auto px-6 py-8 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {heroFacts.map((f) => (
          <div>
            <p class="font-display text-3xl text-rose leading-none">{f.stat}</p>
            <p class="mt-2 text-sm text-ink/65 leading-snug">{f.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TILE GRID -->
    <section class="max-w-6xl mx-auto px-6 py-12">
      <p class="text-xs uppercase tracking-[0.3em] text-sage">Pick a topic</p>
      <h2 class="font-display text-3xl md:text-4xl mt-2">Where do you want to go?</h2>

      <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {groups.map((g) => {
          const m = tileMeta[g.id] ?? { icon: '◯', tone: 'bg-ink/5 text-ink/60 border-ink/10' };
          return (
            <a
              href={`#panel-${g.id}`}
              class="tile group bg-white border border-ink/5 rounded-2xl p-5 hover:border-rose/40 hover:shadow-md transition-all duration-200 flex flex-col gap-3"
              data-tile={g.id}
            >
              <div class={`w-10 h-10 rounded-xl border flex items-center justify-center text-lg font-display ${m.tone}`}>
                {m.icon}
              </div>
              <h3 class="font-display text-xl leading-tight">{g.title}</h3>
              <p class="text-sm text-ink/60 leading-snug flex-1">{g.intro}</p>
              <p class="text-xs text-rose font-medium mt-auto">
                {g.sections.length} {g.sections.length === 1 ? 'section' : 'sections'} →
              </p>
            </a>
          );
        })}
      </div>
    </section>

    <!-- DETAIL PANELS -->
    <section class="max-w-6xl mx-auto px-6 pb-20 space-y-16">
      {groups.map((g, gi) => (
        <div id={`panel-${g.id}`} class="scroll-mt-24">
          <div class="flex items-start justify-between gap-6 border-b border-ink/10 pb-4">
            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-sage">
                Topic {String(gi + 1).padStart(2, '0')}
              </p>
              <h2 class="font-display text-3xl md:text-4xl mt-1">{g.title}</h2>
              <p class="mt-2 text-ink/70 max-w-2xl">{g.intro}</p>
            </div>
            <a href="#top" class="text-xs text-ink/50 hover:text-rose whitespace-nowrap shrink-0 mt-2">↑ Back to tiles</a>
          </div>

          {g.id === 'basics' && (
            <div class="mt-6">
              <MediaPlaceholder kind="video" ratio="16/9" label="Explainer · 2 min" caption="Optional video: what collagen looks like under a microscope and why it matters." tone="sage" />
            </div>
          )}

          <div class="mt-8 grid md:grid-cols-2 gap-4">
            {g.sections.map((s) => (
              <details
                id={s.id}
                class="card bg-white border border-ink/5 rounded-2xl overflow-hidden open:shadow-md transition"
              >
                <summary class="cursor-pointer list-none p-5 hover:bg-bone/40 transition flex items-start gap-3">
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      {s.evidence && (
                        <span class={`text-[10px] uppercase tracking-widest font-semibold px-2 py-0.5 rounded-full ${evidencePillClass(s.evidence)}`}>
                          {evidenceLabels[s.evidence]}
                        </span>
                      )}
                      {s.focus && s.focus !== 'general' && (
                        <span class="text-[10px] uppercase tracking-widest font-semibold px-2 py-0.5 rounded-full bg-bone text-ink/60 border border-ink/10">
                          {focusLabels[s.focus]}
                        </span>
                      )}
                    </div>
                    <h3 class="font-display text-lg leading-tight">{s.title}</h3>
                    <p class="mt-1.5 text-sm text-ink/70 leading-snug">{s.tldr}</p>
                  </div>
                  <span class="caret shrink-0 mt-1 text-ink/40 group-open:rotate-45 transition-transform">＋</span>
                </summary>
                <div class="px-5 pb-5 pt-0 prose-card text-ink/85 text-[15px]">
                  {/* Image inside the body for benefit and therapy cards */}
                  {(g.id === 'boost-clinical' || g.id === 'boost-topical') && (
                    <MediaPlaceholder kind="image" ratio="16/9" label={`${s.title} · before/after`} tone="bone" class="mt-1 mb-4" />
                  )}
                  <div set:html={s.bodyHtml}></div>
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </section>

    <p class="max-w-6xl mx-auto px-6 pb-20 text-xs text-ink/50 italic">
      Educational content, not medical advice. Consult a qualified clinician before starting
      supplements or treatments.
    </p>
  </article>

  <style>
    details > summary::-webkit-details-marker { display: none; }
    details > summary { list-style: none; }
    .caret { display: inline-block; }
    details[open] .caret { transform: rotate(45deg); }

    .tile:hover h3 { color: var(--color-rose); }

    .prose-card :global(p) { margin-block: 0.7em; line-height: 1.7; }
    .prose-card :global(p:first-child) { margin-top: 0; }
    .prose-card :global(a) { color: var(--color-rose); text-decoration: underline; text-decoration-color: rgba(184,130,109,0.4); }
    .prose-card :global(h4) { font-size: 1rem; margin-top: 1.2em; margin-bottom: 0.4em; }
    .prose-card :global(ul), .prose-card :global(ol) { margin-block: 0.7em; padding-left: 1.2em; }
    .prose-card :global(ul) { list-style: disc; }
    .prose-card :global(ol) { list-style: decimal; }
    .prose-card :global(li) { margin-block: 0.3em; line-height: 1.65; }

    @media (prefers-reduced-motion: reduce) {
      .tile, details { transition: none; }
    }
  </style>

  <script is:inline>
    // Highlight the linked tile briefly when its panel is targeted.
    (function () {
      function flashTile() {
        const id = location.hash.replace('#panel-', '');
        if (!id) return;
        document.querySelectorAll('.tile').forEach((t) => {
          t.classList.toggle('ring-2', t.getAttribute('data-tile') === id);
          t.classList.toggle('ring-rose', t.getAttribute('data-tile') === id);
        });
      }
      window.addEventListener('hashchange', flashTile);
      flashTile();
    })();
  </script>
</BaseLayout>
